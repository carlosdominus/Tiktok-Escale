{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] }
      },
      "required": ["uid", "email"]
    },
    "Sale": {
      "title": "Sale",
      "description": "A completed sale transaction",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "packageId": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "paid", "expired"] },
        "pixCode": { "type": "string" },
        "externalId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "accounts": { "type": "string", "description": "Serialized JSON of accounts delivered" }
      },
      "required": ["userId", "packageId", "amount", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/sales/{saleId}": {
      "schema": "Sale",
      "description": "Sales transactions"
    }
  }
}
